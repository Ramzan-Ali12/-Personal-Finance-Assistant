# ============================================================================
#  Personal Finance Assistant — backend configuration
#  Copy this file to `.env` and fill in your own values.
#  The app runs fully WITHOUT any LLM key (it falls back to a deterministic
#  "mock" LLM), so you can demo the whole system offline.
# ============================================================================

# --- Database -------------------------------------------------------------
# Local Postgres with the pgvector extension installed.
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/finance

# --- Auth -----------------------------------------------------------------
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days

# --- LLM provider (OpenAI-compatible: OpenRouter, OpenAI, Together, Ollama) -
# Leave LLM_API_KEY empty to run in deterministic MOCK mode (no network).
LLM_PROVIDER=openrouter
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=

# Model tiers — cheap model for routing/summaries, stronger for agent/vision.
LLM_ROUTER_MODEL=anthropic/claude-3.5-haiku
LLM_AGENT_MODEL=anthropic/claude-3.5-sonnet
LLM_VISION_MODEL=anthropic/claude-3.5-sonnet

# --- Embeddings -----------------------------------------------------------
# If EMBEDDINGS_API_KEY is empty, a dependency-free local hashing embedder is
# used (good enough to demo RAG; swap for a real model in production).
EMBEDDINGS_PROVIDER=local
EMBEDDINGS_BASE_URL=https://openrouter.ai/api/v1
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDINGS_DIM=384

# --- Web search tool (unknown merchant lookup, capability #7) --------------
# Optional. If empty, merchant lookup degrades to LLM-only best-effort.
WEB_SEARCH_PROVIDER=none          # none | tavily | serpapi
WEB_SEARCH_API_KEY=

# --- CORS -----------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
